{
    "name": "@jwalton/create-ts-app",
    "version": "1.1.0",
    "description": "",
    "author": {
        "name": "Jason Walton",
        "email": "dev@lucid.thedreaming.org"
    },
    "license": "MIT",
    "sideEffects": false,
    "main": "./dist/index.js",
    "bin": {
        "create-ts-app": "./dist/index.js"
    },
    "type": "module",
    "files": [
        "dist/**/*",
        "template/**/*"
    ],
    "scripts": {
        "start": "npm run build && node dist/index.js",
        "test": "npm run build && npm run lint && npm run test:unittest",
        "build": "swc ./src -d dist --strip-leading-paths --ignore '**/*.spec.ts'",
        "clean": "rm -rf dist types coverage",
        "test:unittest": "c8 mocha",
        "lint": "npm run lint:source && npm run lint:types",
        "lint:source": "eslint src",
        "lint:types": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
        "prepare": "husky || true",
        "prepublishOnly": "npm run build && npm test",
        "semantic-release": "semantic-release"
    },
    "lint-staged": {
        "**/*.@(ts|tsx)": [
            "prettier --write",
            "eslint"
        ],
        "**/*.@(js|cjs|mjs|jsx)": [
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jwalton/create-ts-app.git"
    },
    "keywords": [
        ""
    ],
    "bugs": {
        "url": "https://github.com/jwalton/create-ts-app/issues"
    },
    "homepage": "https://github.com/jwalton/create-ts-app#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@swc/cli": "^0.8.0",
        "@swc/core": "^1.15.18",
        "@types/chai": "^5.2.3",
        "@types/inquirer-npm-name": "^3.0.7",
        "@types/lodash": "^4.17.24",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.19.37",
        "@types/sinon": "^21.0.0",
        "@types/yargs": "^17.0.32",
        "c8": "^11.0.0",
        "chai": "^6.2.2",
        "eslint": "^10.0.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.3",
        "mocha": "^11.7.5",
        "prettier": "^3.8.1",
        "sinon": "^21.0.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "dependencies": {
        "inquirer": "^13.3.0",
        "inquirer-npm-name": "^4.0.0",
        "lodash": "^4.17.23",
        "yargs": "^18.0.0"
    }
}
